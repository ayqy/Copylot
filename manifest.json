{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.2.2",
  "description": "__MSG_appDescription__",
  "homepage_url": "https://copy.useai.online/",
  "default_locale": "en",
  "permissions": [
    "storage",
    "clipboardWrite",
    "contextMenus"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/turndown.js",
        "src/turndown-plugin-gfm.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "commands": {
    "quick-convert": {
      "suggested_key": {
        "default": "Alt+C",
        "mac": "Alt+C"
      },
      "description": "__MSG_commandQuickConvertDescription__"
    },
    "quick-prompt-slot-1": {
      "suggested_key": {
        "default": "Alt+1",
        "mac": "Alt+1"
      },
      "description": "__MSG_commandQuickPrompt1Description__"
    },
    "quick-prompt-slot-2": {
      "suggested_key": {
        "default": "Alt+2",
        "mac": "Alt+2"
      },
      "description": "__MSG_commandQuickPrompt2Description__"
    },
    "quick-prompt-slot-3": {
      "suggested_key": {
        "default": "Alt+3",
        "mac": "Alt+3"
      },
      "description": "__MSG_commandQuickPrompt3Description__"
    }
  },
  "options_page": "src/options/options.html",
  "devtools_page": "src/devtools/devtools.html",
  "web_accessible_resources": [
    {
      "resources": [
        "src/assets/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
